# ─── Supabase (빌드 타임 번들 — 공개 OK) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── 서버사이드 전용 (Vercel 환경변수로 설정 — 절대 공개 금지) ─────────────────
# shop-api(catalog/cart/review/notification) URL (Railway 등 배포 후 실제 URL로 변경)
API_BASE_URL=https://your-backend.railway.app
# order-api(order+inventory, MSA S3-3b) URL — shop-api와 분리된 별도 서비스
ORDER_SERVICE_URL=https://your-order-service.railway.app
# order-admin(관리자 전용 주문, MSA S4) URL — order-api와 분리된 별도 서비스
ORDER_ADMIN_SERVICE_URL=https://your-order-admin-service.railway.app

# BFF 터널 키 — 백엔드 BFF_SECRET_KEY와 반드시 동일한 값
BFF_SECRET_KEY=your-bff-secret-key-min-32-chars

# ─── 분산 트레이싱(로컬 전용, GH #7) ──────────────────────────────────────────
# @vercel/otel OTLP export 대상. instrumentation.ts가 이 값 뒤에 "/v1/traces"를 자동으로
# 붙인다. kind + OTel Collector(k8s/observability/) 기준: ingress-nginx가 /otlp 접두어를
# 벗겨 Collector로 전달하므로 http://localhost/otlp 로 지정(2026-07-15, ADR-018 후속).
# compose 시절 Tempo 직결 기본값은 http://localhost:4318 이었음(port 노출 방식, 폐기).
OTLP_TRACING_ENDPOINT=http://localhost/otlp
